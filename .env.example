# OFPPT Specs Manager - Configuration Environnement
# Copier ce fichier en .env.local et remplir les valeurs

# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@localhost:5432/ofppt_manager

# Port du serveur API
PORT=8082

# Chemin de base
BASE_PATH=/

# Clé API Gemini (gratuite sur https://aistudio.google.com/apikey)
GEMINI_API_KEY=VOTRE_CLE_GEMINI_ICI
