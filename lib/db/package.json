{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "node --env-file=../../.env.local --env-file=../../.env -e \"import('node:child_process').then(cp => cp.execSync('drizzle-kit push --config ./drizzle.config.ts', {stdio:'inherit', env: process.env}))\"",
    "push-force": "node --env-file=../../.env.local --env-file=../../.env -e \"import('node:child_process').then(cp => cp.execSync('drizzle-kit push --force --config ./drizzle.config.ts', {stdio:'inherit', env: process.env}))\""
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  }
}
